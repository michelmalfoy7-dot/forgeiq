{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/weekly-recap",
      "schedule": "0 16 * * 0"
    },
    {
      "path": "/api/cron/workout-reminder",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/push-insight",
      "schedule": "0 7 * * *"
    }
  ]
}
