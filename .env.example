# ============================================================
# ForgeIQ — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# Entrer ces mêmes clés dans : Vercel > Settings > Environment Variables
# ============================================================

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# App URL (localhost en dev, domaine Vercel en prod)
NEXT_PUBLIC_APP_URL=https://forgeiq.vercel.app

# Stripe — https://dashboard.stripe.com/apikeys
# 1. Crée 3 produits dans Stripe : Pro Mensuel, Pro Annuel, Lifetime
# 2. Copie les Price IDs (price_...) ci-dessous
# 3. Pour le webhook : Stripe Dashboard → Webhooks → Add endpoint → URL: https://TON_DOMAINE/api/webhooks/stripe
#    Events : customer.subscription.created/updated/deleted · checkout.session.completed · invoice.payment_failed
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
STRIPE_PRICE_LIFETIME=price_...

# PostHog Analytics (optionnel) — https://posthog.com
# Crée un projet sur app.posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Email admin pour les notifications Stripe (nouveaux abonnés, échecs paiement…)
# Ne jamais hard-coder : utiliser l'adresse email qui reçoit les alertes
ADMIN_EMAIL=admin@getforgeiq.com
